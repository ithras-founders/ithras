{
  "id": "global_ultra_minimal",
  "name": "Ultra Minimal",
  "group": "global",
  "group_label": "Global",
  "institution_id": null,
  "college_slug": null,
  "status": "PUBLISHED",
  "batch_ids": [],
  "program_ids": [],
  "config": {
    "page": {
      "size": "A4",
      "margins": { "top": 16, "bottom": 16, "left": 18, "right": 18 },
      "border": "none"
    },
    "typography": {
      "baseFont": { "family": "'Helvetica Neue', Helvetica, sans-serif", "size": 9, "lineHeight": 1.4 },
      "headerFont": {
        "sizes": { "h1": 24, "h2": 11, "h3": 9 },
        "weights": { "h1": 300, "h2": 500, "h3": 400 }
      },
      "bulletStyle": "circle",
      "bulletIndentation": 2
    },
    "spacing": {
      "lineSpacing": 1.5,
      "bulletSpacing": 0.25,
      "sectionTitleBefore": 1.2,
      "sectionTitleAfter": 0.6,
      "sectionSpacing": 0.8,
      "rowSpacing": 0,
      "boxGap": 0
    },
    "designTokens": {
      "lineColor": "#D1D5DB",
      "primary": "#6B7280",
      "accent": "#6B7280",
      "charcoalBar": "#9CA3AF",
      "labelFill": "#F9FAFB",
      "gridLineColor": "#D1D5DB",
      "instituteBrown": "#4B5563"
    },
    "fixedElements": {
      "header": {
        "layout": "split",
        "logoUrl": "",
        "leftContent": "",
        "rightVariables": ["name", "email"],
        "logoPosition": "left",
        "height": 5,
        "textColor": "#111827",
        "dividerAfter": true
      },
      "summaryBar": null,
      "footer": {
        "content": "{{email}}",
        "variables": ["email"],
        "alignment": "center"
      }
    },
    "autoVariables": ["name", "roll_number", "email"],
    "sections": [
      {
        "id": "experience",
        "title": "Experience",
        "optional": true,
        "layoutStyle": "vertical_label_grouped",
        "verticalLabelFieldId": "employment_type",
        "sectionHeaderStyle": {
          "backgroundColor": "transparent",
          "textColor": "#374151",
          "titleCaps": false,
          "titleAlign": "left"
        },
        "groupLabelStyle": { "backgroundColor": "#F9FAFB", "color": "#6B7280" },
        "entryHeaderBucketStyle": { "backgroundColor": "#F9FAFB" },
        "gridWidths": { "verticalBand": "2%", "categoryLabel": "16%", "bullets": "82%" },
        "removePerBulletYears": true,
        "durationAutoCalculate": true,
        "headerFields": ["company", "role", "duration"],
        "entryTypes": [{
          "id": "default",
          "name": "Experience",
          "repeatable": true,
          "fields": [
            { "id": "employment_type", "label": "Type", "type": "dropdown", "options": ["Full Time", "Intern"] },
            { "id": "company", "label": "Company", "type": "text" },
            { "id": "role", "label": "Role", "type": "text" },
            { "id": "start_date", "label": "Start", "type": "date" },
            { "id": "end_date", "label": "End", "type": "date" },
            { "id": "duration", "label": "Duration", "type": "text" },
            { "id": "achievementBuckets", "label": "Achievements", "type": "bucket_list", "richText": true, "allowProofPerItem": true }
          ]
        }],
        "order": 0
      },
      {
        "id": "education",
        "title": "Education",
        "layoutStyle": "two_column",
        "sectionHeaderStyle": {
          "backgroundColor": "transparent",
          "textColor": "#374151",
          "titleCaps": false,
          "titleAlign": "left"
        },
        "entryTypes": [{
          "id": "default",
          "name": "Qualification",
          "repeatable": false,
          "fields": [{
            "id": "qualifications_table",
            "label": "Education",
            "type": "table",
            "columns": [
              { "id": "degree", "label": "Degree", "align": "left", "width": "32%" },
              { "id": "institute", "label": "Institution", "align": "left", "width": "48%" },
              { "id": "percentage", "label": "Score", "align": "center", "width": "10%" },
              { "id": "year", "label": "Year", "align": "center", "width": "10%" }
            ],
            "tableBorderStyle": "1px solid #D1D5DB",
            "tableHeaderBackground": "#F9FAFB",
            "tableCellBackground": "#fff"
          }]
        }],
        "order": 1
      },
      {
        "id": "achievements",
        "title": "Key Achievements",
        "optional": true,
        "layoutStyle": "label_left_content_right",
        "sectionHeaderStyle": {
          "backgroundColor": "transparent",
          "textColor": "#374151",
          "titleCaps": false,
          "titleAlign": "left",
          "labelWidth": "20%"
        },
        "gridWidths": { "label": "20%", "bullets": "75%", "year": "5%" },
        "useDynamicBuckets": true,
        "subCategories": [],
        "entryTypes": [{ "id": "default", "name": "Entry", "repeatable": false, "fields": [] }],
        "order": 2
      }
    ]
  }
}
