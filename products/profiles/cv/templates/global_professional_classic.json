{
  "id": "global_timeline",
  "name": "Timeline",
  "group": "global",
  "group_label": "Global",
  "institution_id": null,
  "college_slug": null,
  "status": "PUBLISHED",
  "batch_ids": [],
  "program_ids": [],
  "config": {
    "page": {
      "size": "A4",
      "margins": { "top": 8, "bottom": 8, "left": 12, "right": 12 },
      "border": "none"
    },
    "typography": {
      "baseFont": { "family": "Arial, Helvetica, sans-serif", "size": 8, "lineHeight": 1.15 },
      "headerFont": {
        "sizes": { "h1": 14, "h2": 9, "h3": 8 },
        "weights": { "h1": 700, "h2": 700, "h3": 600 }
      },
      "bulletStyle": "disc",
      "bulletIndentation": 2.5
    },
    "spacing": {
      "lineSpacing": 1.05,
      "bulletSpacing": 0.08,
      "sectionTitleBefore": 0.3,
      "sectionTitleAfter": 0.2,
      "sectionSpacing": 0.25,
      "rowSpacing": 0,
      "boxGap": 0
    },
    "designTokens": {
      "lineColor": "#0EA5E9",
      "primary": "#0369A1",
      "accent": "#0284C7",
      "charcoalBar": "#0369A1",
      "labelFill": "#E0F2FE",
      "gridLineColor": "#0EA5E9",
      "instituteBrown": "#0284C7"
    },
    "fixedElements": {
      "header": {
        "layout": "split",
        "logoUrl": "",
        "leftContent": "{{name}}",
        "rightVariables": ["roll_number", "email"],
        "logoPosition": "left",
        "height": 3.5,
        "textColor": "#0C4A6E",
        "dividerAfter": true
      },
      "summaryBar": null,
      "footer": {
        "content": "{{email}}",
        "variables": ["email"],
        "alignment": "center"
      }
    },
    "autoVariables": ["name", "roll_number", "email"],
    "sections": [
      {
        "id": "experience",
        "title": "Experience",
        "layoutStyle": "vertical_label_grouped",
        "verticalLabelFieldId": "employment_type",
        "sectionHeaderStyle": {
          "backgroundColor": "#0369A1",
          "textColor": "#fff",
          "titleCaps": true,
          "titleAlign": "left"
        },
        "groupLabelStyle": { "backgroundColor": "#E0F2FE", "color": "#0C4A6E" },
        "entryHeaderBucketStyle": { "backgroundColor": "#E0F2FE" },
        "gridWidths": { "verticalBand": "3%", "categoryLabel": "15%", "bullets": "82%" },
        "removePerBulletYears": true,
        "durationAutoCalculate": true,
        "headerFields": ["company", "role", "duration"],
        "entryTypes": [{
          "id": "default",
          "name": "Experience",
          "repeatable": true,
          "fields": [
            { "id": "employment_type", "label": "Type", "type": "dropdown", "options": ["Full Time", "Intern"] },
            { "id": "company", "label": "Company", "type": "text" },
            { "id": "role", "label": "Role", "type": "text" },
            { "id": "start_date", "label": "Start", "type": "date" },
            { "id": "end_date", "label": "End", "type": "date" },
            { "id": "duration", "label": "Duration", "type": "text" },
            { "id": "achievementBuckets", "label": "Achievements", "type": "bucket_list", "richText": true, "allowProofPerItem": true }
          ]
        }],
        "order": 0
      },
      {
        "id": "education",
        "title": "Education",
        "layoutStyle": "two_column",
        "sectionHeaderStyle": {
          "backgroundColor": "#0369A1",
          "textColor": "#fff",
          "titleCaps": true,
          "titleAlign": "left"
        },
        "entryTypes": [{
          "id": "default",
          "name": "Qualification",
          "repeatable": false,
          "fields": [{
            "id": "qualifications_table",
            "label": "Education",
            "type": "table",
            "columns": [
              { "id": "degree", "label": "Degree", "align": "left", "width": "28%" },
              { "id": "institute", "label": "Institution", "align": "left", "width": "48%" },
              { "id": "percentage", "label": "%/CGPA", "align": "center", "width": "11%" },
              { "id": "year", "label": "Year", "align": "center", "width": "13%" }
            ],
            "tableBorderStyle": "1px solid #0EA5E9",
            "tableHeaderBackground": "#E0F2FE",
            "tableCellBackground": "#F0F9FF"
          }]
        }],
        "order": 1
      },
      {
        "id": "achievements",
        "title": "Key Achievements",
        "optional": true,
        "layoutStyle": "label_left_content_right",
        "sectionHeaderStyle": {
          "backgroundColor": "#0369A1",
          "textColor": "#fff",
          "titleCaps": true,
          "titleAlign": "left",
          "labelWidth": "18%"
        },
        "gridWidths": { "label": "18%", "bullets": "77%", "year": "5%" },
        "useDynamicBuckets": true,
        "subCategories": [],
        "entryTypes": [{ "id": "default", "name": "Entry", "repeatable": false, "fields": [] }],
        "order": 2
      }
    ]
  }
}
