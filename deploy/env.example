# deploy/env.example
#
# Cloud Build trigger substitution variables for Ithras deployment.
# Copy these values into your Cloud Build trigger configuration.
# Never commit actual secret values to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# GCP Cloud SQL instance connection name (PROJECT:REGION:INSTANCE)
_CLOUD_SQL_INSTANCE=my-project:europe-west1:ithras-db

# Full PostgreSQL connection URL using the Cloud SQL Auth Proxy Unix socket.
# Cloud Run attaches the socket at /cloudsql/<INSTANCE_CONNECTION_NAME>/.s.PGSQL.5432
# Format: postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/INSTANCE_CONNECTION_NAME
_DATABASE_URL=postgresql://ithras:PASSWORD@/placement_db?host=/cloudsql/my-project:europe-west1:ithras-db

# JWT signing secret — generate with: openssl rand -hex 32
_JWT_SECRET=

# Google Gemini API key
_GEMINI_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────

# Cloud Run region (default: europe-west1)
_REGION=europe-west1

# Cloud Run service names
_BACKEND_SERVICE=ithras-backend
_FRONTEND_SERVICE=ithras-frontend

# Artifact Registry repository path (relative to project)
_REGISTRY=cloud-run-source-deploy/ithras

# Redis connection string (leave empty to disable)
_REDIS_URL=

# Seeded demo account password
_DEMO_PASSWORD=password

# Backend public URL — if empty, resolved automatically from Cloud Run after deploy
# Set this explicitly when using a custom domain to avoid a lookup round-trip
_BACKEND_URL=

# Cloud Run service account email (recommended; leave empty to use Compute default)
_SERVICE_ACCOUNT=ithras-backend-sa@my-project.iam.gserviceaccount.com

# Cloud Run instance scaling
_MIN_INSTANCES=0
_MAX_INSTANCES=10
